
{
  "name": "Eyerest Reminder!",
  "description": "This is a simple extension to remind you to rest your eye once in few minutes.",
  "version": "1.0",
  "manifest_version": 3,
  "action": {
    "default_popup": "eye-rest.html",
    "default_icon": "assets/favicon.ico"
  },

  "permissions": ["scripting", "activeTab", "tabs", "storage", "notifications"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "scripts/background.js"
  },

  "web_accessible_resources": [
    {
      "resources": ["assets/sheep_item.svg", "styles/blocker.css"],
      "matches": ["<all_urls>"]
    }
  ]
}