
{
  "name": "Eyerest Reminder!",
  "description": "This is a simple extension to remind you to rest your eye once in few minutes.",
  "version": "1.0",
  "manifest_version": 3,
  "action": {
    "default_popup": "eye-rest.html",
    "default_icon": "eye_icon.png"
  },

  "content_scripts": [
    {
      "js": ["scripts/content.js"],
      "css": ["style.css"],
      "matches": [
        // "https://developer.chrome.com/docs/extensions/*",
        // "https://developer.chrome.com/docs/webstore/*"

        "<all_urls>"
      ]
    }
  ]

}